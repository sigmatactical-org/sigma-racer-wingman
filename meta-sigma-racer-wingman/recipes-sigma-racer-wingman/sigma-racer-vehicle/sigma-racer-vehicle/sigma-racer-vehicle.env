# sigma-racer-vehicle — SocketCAN on i.MX 8M Plus (FlexCAN can0)
SIGMA_RACER_WINGMAN_VEHICLE_SOURCE=socketcan
SIGMA_RACER_WINGMAN_CAN_IFACE=can0
SIGMA_RACER_WINGMAN_CAN_BITRATE=1000000
SIGMA_RACER_WINGMAN_VEHICLE_DEMO=0
SIGMA_RACER_WINGMAN_TELEMETRY_SOCKET=/run/sigma-racer-wingman/vehicle.sock
# Uncomment to capture decoded CAN frames as MDF4 (requires writable path):
# SIGMA_RACER_WINGMAN_CAN_LOG_PATH=/var/log/sigma-racer-wingman/can.mf4
